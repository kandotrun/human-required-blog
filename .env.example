# World ID / IDKit
NEXT_PUBLIC_WORLD_APP_ID=app_your_world_app_id
NEXT_PUBLIC_WORLD_RP_ID=rp_your_relying_party_id
WORLD_RP_ID=rp_your_relying_party_id
WORLD_SIGNING_KEY=0x_your_world_id_signing_private_key
NEXT_PUBLIC_WORLD_ENVIRONMENT=production

# App session signing. Generate with: openssl rand -base64 48
HUMAN_SESSION_SECRET=replace-with-a-long-random-secret

# Optional local SQLite path. Defaults to data/comments.sqlite
# COMMENTS_DB_PATH=./data/comments.sqlite

# Local UI smoke tests only. Ignored in production by code.
# HUMAN_DEV_BYPASS=1
